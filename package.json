{
    "name": "aljabr",
    "author": "ja.superior",
    "version": "0.3.5",
    "description": "A TypeScript library for modeling data with tagged union types (algebraic sum types), consuming them with exhaustive pattern matching, and composing reactive computations with signals",
    "license": "Apache-2.0",
    "keywords": [
        "typescript",
        "algebraic-data-types",
        "tagged-union",
        "sum-types",
        "pattern-matching",
        "functional-programming",
        "signals",
        "reactive"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/jasuperior/aljabr.git"
    },
    "homepage": "https://github.com/jasuperior/aljabr",
    "bugs": {
        "url": "https://github.com/jasuperior/aljabr/issues"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/main.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/main.d.ts"
        },
        "./prelude": {
            "import": "./dist/prelude.js",
            "require": "./dist/prelude.cjs",
            "types": "./dist/prelude/index.d.ts"
        },
        "./schema": {
            "import": "./dist/schema.js",
            "require": "./dist/schema.cjs",
            "types": "./dist/schema/index.d.ts"
        },
        "./signals": {
            "import": "./dist/signals.js",
            "require": "./dist/signals.cjs",
            "types": "./dist/signals/index.d.ts"
        },
        "./ui": {
            "import": "./dist/ui.js",
            "require": "./dist/ui.cjs",
            "types": "./dist/ui/index.d.ts"
        },
        "./ui/dom": {
            "import": "./dist/ui-dom.js",
            "require": "./dist/ui-dom.cjs",
            "types": "./dist/ui/dom/index.d.ts"
        },
        "./ui/jsx-runtime": {
            "import": "./dist/ui-jsx-runtime.js",
            "require": "./dist/ui-jsx-runtime.cjs",
            "types": "./dist/ui/jsx-runtime.d.ts"
        },
        "./ui/jsx-dev-runtime": {
            "import": "./dist/ui-jsx-dev-runtime.js",
            "require": "./dist/ui-jsx-dev-runtime.cjs",
            "types": "./dist/ui/jsx-dev-runtime.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "release": "np",
        "release:patch": "np patch",
        "release:minor": "np minor",
        "release:major": "np major"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.2",
        "np": "^11.0.3",
        "typescript": "~5.9.3",
        "vite": "^8.0.5",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.2"
    }
}
